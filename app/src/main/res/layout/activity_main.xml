<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_size"
    android:layout_height="match_parent"
    android:background="@color/background_gradient_start"
    android:padding="16dp"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- App Title Header Block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/logoImage"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/primary_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DoubleTap Screen Lock"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe, Ultra low battery usage, Premium M3"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Status Indicator Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERVICE STATUSES"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- Accessibility Service status -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accessibility Service"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvAccessibilityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="@string/service_inactive_status"
                            android:textColor="@color/status_red"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Device Admin Status -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Device Policy Fallback"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvAdminStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="@string/service_inactive_status"
                            android:textColor="@color/status_red"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Background Floating Touch Bar Service Status -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Floating Double Tap Widget"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvWidgetStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="@string/service_inactive_status"
                            android:textColor="@color/status_red"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Accelerometer double-tap status -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accelerometer Core Tap"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvSensorStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="@string/service_inactive_status"
                            android:textColor="@color/status_red"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Configuration Options and Switches -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SYSTEM CONFIGURATION"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- Enable/Disable Floating Widget Switch -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchFloatingWidget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Enable Floating Lock Bar"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Creates a premium, transparent movable overlay on the edge of your screen. Double-tap it to immediately lock."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginLeft="4dp" />

                    <!-- Enable/Disable Accelerometer Switch -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchAccelerometer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Enable Physical Sensor Tap"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Detects physical taps on the body or back of the phone via high-frequency accelerometer processing."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginLeft="4dp" />

                    <!-- Lock Click sound feedback switch -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchSound"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Premium Lock Click Sound"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:checked="true" />

                    <!-- Vibration switch -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchVibration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Tactile Vibration Feedback"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:checked="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Triggers a 70ms vibration feedback on locking confirmation."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginLeft="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Permissions Actions Panel -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REQUIRED PERMISSIONS SETUP"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- Accessibility activation button -->
                    <Button
                        android:id="@+id/btnToggleAccessibility"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Accessibility Service"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white" />

                    <!-- Device admin fallback button -->
                    <Button
                        android:id="@+id/btnToggleAdmin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enable Device Admin Fallback"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/accent"
                        android:textColor="@color/white" />

                    <!-- Ignore Battery Optimization Button -->
                    <Button
                        android:id="@+id/btnIgnoreBattery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Whitelist Battery Optimization"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/card_bg_active"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Whitelisting battery optimization ensures background accelerometer or floating widgets are not terminated by Android OS."
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Wallpaper Customization Panel -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOUBLE-TAP WALLPAPER SETUP"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="To double-tap anywhere on your home screen to lock, set this app's Live Wallpaper. You can load any custom photo/wallpaper of your choice from your gallery to keep your home screen personalized!"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                    <!-- Choose Custom Wallpaper Button -->
                    <Button
                        android:id="@+id/btnChooseWallpaper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose Custom Background Photo"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white" />

                    <!-- Set Live Wallpaper System Prompt Button -->
                    <Button
                        android:id="@+id/btnSetLiveWallpaper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Apply Live Wallpaper to Home Screen"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/accent"
                        android:textColor="@color/white" />

                    <!-- Reset to default slate color -->
                    <Button
                        android:id="@+id/btnResetWallpaper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset to Default Dark Slate Background"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="8dp"
                        android:backgroundTint="@color/card_bg_active"
                        android:textColor="@color/white" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Interactive double tap test pad -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnTestPad"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg_active"
                android:layout_marginBottom="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/primary_light"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_status"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOUBLE TAP HERE TO TEST LOCK"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Simulates gesture lock with audio &amp; vibration feedback"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About / Footer Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About DoubleTapScreenLock"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:underline="true" />

                <TextView
                    android:id="@+id/tvPrivacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy Policy"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:underline="true"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version 1.0.0 • Java Only Android Studio Project"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
